# PostgreSQL (AWS RDS) — copy to .env and fill in
RDS_HOST=
RDS_PORT=5432
RDS_DATABASE=
RDS_USER=
RDS_PASSWORD=

# Schemas (replace N with your group number)
BRONZE_SCHEMA=bronze_groupN
SILVER_SCHEMA=silver_groupN
GOLD_SCHEMA=gold_groupN

# AWS S3 — extract step
S3_BUCKET_NAME=kickz-empire-data
S3_PREFIX=raw
AWS_REGION=eu-west-3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
